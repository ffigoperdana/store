PORT=3000
DATABASE_URL=postgresql://fgstore:local-development-only@db:5432/fgstore
POSTGRES_PASSWORD=local-development-only
SESSION_SECRET=replace-with-a-long-random-secret-before-production
INVENTORY_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=change-this-before-production
ADMIN_NAME=FG Store Owner
STORE_WHATSAPP=6281234567890
# Keep this true/empty in Coolify HTTPS. Docker local uses false automatically.
COOKIE_SECURE=true
PAYMENT_PROVIDER=mock
# Only for local Docker testing. Never enable in a deployed store.
ALLOW_MOCK_PAY=false
# Set false only if you want to start with a completely empty catalogue.
AUTO_SEED_CATALOG=true
KLIKQRIS_ENV=sandbox
KLIKQRIS_MODE=PG
KLIKQRIS_API_KEY=
KLIKQRIS_MERCHANT_ID=
# Required for real callbacks during local Docker testing: public HTTPS tunnel URL.
PUBLIC_BASE_URL=
