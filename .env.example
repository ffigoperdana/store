PORT=3000
DATABASE_URL=postgresql://fgstore:local-development-only@db:5432/fgstore
POSTGRES_PASSWORD=local-development-only
SESSION_SECRET=replace-with-a-long-random-secret-before-production
INVENTORY_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=change-this-before-production
ADMIN_NAME=FG Store Owner
STORE_WHATSAPP=6281234567890
# Keep this true/empty in Coolify HTTPS. Docker local uses false automatically.
COOKIE_SECURE=true
PAYMENT_PROVIDER=mock
# Only for local Docker testing. Never enable in a deployed store.
ALLOW_MOCK_PAY=false
# Seeds the production starter catalogue idempotently; no fake buyers/orders.
# Set false only if you want to start with a completely empty catalogue.
AUTO_SEED_CATALOG=true
# Enable only for Docker-local UI testing. Keep false in Coolify.
SEED_DEMO_DATA=false
KLIKQRIS_ENV=sandbox
KLIKQRIS_MODE=PG
KLIKQRIS_API_KEY=
KLIKQRIS_MERCHANT_ID=
# Public URL milik FG Store (bukan https://klikqris.com/api). In production,
# use https://store.fgdev.tech. Docker-local requires a public HTTPS tunnel.
PUBLIC_BASE_URL=http://localhost:3000
# Transactional delivery email. Cloudflare Email Routing alone cannot send customer email.
EMAIL_PROVIDER=disabled
RESEND_API_KEY=
EMAIL_FROM=FG Store <orders@mail.fgdev.tech>
EMAIL_REPLY_TO=support@fgdev.tech
APP_BASE_URL=http://localhost:3000
# Atomic checkout protection (defaults shown below).
CHECKOUT_RATE_LIMIT_WINDOW_SECONDS=600
CHECKOUT_RATE_LIMIT_IP_MAX=12
CHECKOUT_RATE_LIMIT_PHONE_MAX=5
